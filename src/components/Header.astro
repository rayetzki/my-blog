---
import { SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";
---

<header>
  <nav>
    <h2><a href="/">{SITE_TITLE}</a></h2>
    <div class="social-links">
      <HeaderLink href="https://Pt.me/ukraina_libertaria" target="_blank">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="34px"
          height="34px"
          viewBox="0 0 24 24"
          fill="none"
        >
          <path
            d="M12 4C10.4178 4 8.87103 4.46919 7.55544 5.34824C6.23985 6.22729 5.21447 7.47672 4.60897 8.93853C4.00347 10.4003 3.84504 12.0089 4.15372 13.5607C4.4624 15.1126 5.22433 16.538 6.34315 17.6569C7.46197 18.7757 8.88743 19.5376 10.4393 19.8463C11.9911 20.155 13.5997 19.9965 15.0615 19.391C16.5233 18.7855 17.7727 17.7602 18.6518 16.4446C19.5308 15.129 20 13.5823 20 12C20 9.87827 19.1571 7.84344 17.6569 6.34315C16.1566 4.84285 14.1217 4 12 4ZM15.93 9.48L14.62 15.67C14.52 16.11 14.26 16.21 13.89 16.01L11.89 14.53L10.89 15.46C10.8429 15.5215 10.7824 15.5715 10.7131 15.6062C10.6438 15.6408 10.5675 15.6592 10.49 15.66L10.63 13.66L14.33 10.31C14.5 10.17 14.33 10.09 14.09 10.23L9.55 13.08L7.55 12.46C7.12 12.33 7.11 12.03 7.64 11.83L15.35 8.83C15.73 8.72 16.05 8.94 15.93 9.48Z"
            fill="#000000"></path>
        </svg>
      </HeaderLink>
      <HeaderLink href="rss.xml">
        <svg
          width="24px"
          height="24px"
          viewBox="0 0 512 512"
          xmlns="http://www.w3.org/2000/svg"
        >
            <title>ionicons-v5_logos</title>
            <path d="M108.56,342.78a60.34,60.34,0,1,0,60.56,60.44A60.63,60.63,0,0,0,108.56,342.78Z"></path>
            <path d="M48,186.67v86.55c52,0,101.94,15.39,138.67,52.11s52,86.56,52,138.67h86.66C325.33,312.44,199.67,186.67,48,186.67Z"></path>
            <path d="M48,48v86.56c185.25,0,329.22,144.08,329.22,329.44H464C464,234.66,277.67,48,48,48Z"></path>
        </svg>
      </HeaderLink>
    </div>
  </nav>
</header>
<style>
  header {
    margin: 0;
    background: white;
    position: sticky;
    inset: 0;
    box-shadow:
      0 5px 5px -3px rgb(0,0,0,0.1), 
      0 8px 10px 1px rgba(0,0,0,0.07), 
      0 3px 14px 2px rgba(0,0,0,0.06);
  }
  h2 {
    margin: 0;
    font-size: 2.125rem;
    font-family: var(--content-font);
    font-style: normal;
    font-weight: 700;

    @media screen and (max-width: 720px) {
      font-size: 1.5rem;
    }
  }

  h2 a,
  h2 a.active {
    text-decoration: none;
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 0.75em;
    padding-inline: 1em;
  }
  nav a {
    color: var(--black);
    border-bottom: 4px solid transparent;
    text-decoration: none;
    padding: 0;
    border: none;
  }
  a:has(svg) {
    display: grid;
  }

  .social-links {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1rem;
  }
</style>
